# Ignora file di cache Python e file compilati
__pycache__/
*.py[cod]
*$py.class

# Ignora ambienti virtuali (molto importante!)
venv/
.venv/
env/
env.bak/
venv.bak/

# Ignora file di configurazione IDE/editor
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Ignora file specifici del sistema operativo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.TheEnd
.Trashes
.VolumeIcon.icns
Thumbs.db

# Ignora segreti locali e file di configurazione sensibili
# IMPORTANTE: Assicurati che 'secrets.toml' sia qui se lo usi per test locali
# Se usi Streamlit Cloud e configuri i secrets direttamente lì, questo file
# potrebbe non essere usato, ma è comunque buona norma ignorarlo.
.env
secrets.toml

# Ignora file temporanei creati dall'applicazione
# Adatta questi pattern ai tipi di file che la tua app genera
temp_*
*.tmp
output.log # File di log
*.log

# Ignora file video generati dall'app (se appropriato)
*.mp4
*.mov
*.avi

# Ignora altri file di build o cache
.streamlit/
*.sqlite
*.sqlite3
